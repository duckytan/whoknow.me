  "riderSpeedMult": {
    "_comment": "骑手 → 配送速度倍率（<1 = 快, >1 = 慢）",
    "_schema": "Record<riderId, number>",
    "r001": 0.7,
    "r002": 1.5,
    "r003": 1.2,
    "r004": 0.85,
    "r005": 1.0
  },

  "addressTimeOffset": {
    "_comment": "地址 → 时间偏移（秒）",
    "_schema": "Record<addressName, number>",
    "家庭": 0,
    "学校": 30,
    "公司": 60,
    "公厕": 180,
    "百慕大": 600,
    "ICU": 300
  },

  "addressMeta": {
    "_comment": "地址 → chip 显示文案 + emoji",
    "_schema": "Record<addressName, { label: string, emoji: string }>",
    "家庭": { "label": "家", "emoji": "🏠" },
    "学校": { "label": "上楼配送", "emoji": "🎒" },
