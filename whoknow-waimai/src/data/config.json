{
  "_meta": {
    "version": "1.0.0",
    "updatedAt": "2026-07-22",
    "purpose": "胡闹大脑控制参数 · 所有可调参数集中管理",
    "editPolicy": "改这里 = 改游戏性 · 无需改代码",
    "schema": {
      "schemaVersion": 1,
      "validateWith": "src/utils/config.ts · loadConfig()",
      "migrationNote": "胡闹大脑接入时，schemaVersion 升 2，加 chaosBrain 字段"
    }
  },

  "_brainHooks": {
    "_comment": "胡闹大脑接入点预留（v2 启用）",
    "enabled": false,
    "endpoint": "/api/chaos-brain",
    "fallbackStrategy": "static-then-cache",
    "refreshIntervalSec": 300,
    "overrideKeys": [
      "BOSS_SPEED_MULT",
      "ADDRESS_TIME_OFFSET",
      "REMARK_TIME_OFFSET",
      "LIFESTYLE_MAP"
    ]
  },

