  "demoSpeedOptions": {
    "_comment": "demo 倍速选项",
    "_schema": "Array<{ label: string, value: number, desc: string }>",
    "options": [
      { "label": "×1 真实", "value": 1, "desc": "完全真实时间（30-45 分钟）" },
      { "label": "×5 快速", "value": 5, "desc": "压缩到 6-9 分钟" },
      { "label": "×30 demo", "value": 30, "desc": "1 分钟左右看完剧情" },
      { "label": "×100 跳过", "value": 100, "desc": "10 秒走完一单" }
    ],
    "defaultValue": 30
  },

  "lifestyleMap": {
    "_comment": "真实秒数 → 生活映射文案（戏剧反差）",
    "_schema": "Array<{ maxMinutes: number, text: string }>",
    "brackets": [
      { "maxMinutes": 3, "text": "☕ 一杯咖啡的时间" },
      { "maxMinutes": 8, "text": "📱 刷个短视频" },
      { "maxMinutes": 15, "text": "🍜 一顿饭" },
      { "maxMinutes": 25, "text": "📺 追一集剧" },
      { "maxMinutes": 40, "text": "🎬 看场电影" },
      { "maxMinutes": 60, "text": "🛀 泡个澡" },
      { "maxMinutes": 120, "text": "🛌 睡个午觉" }
    ],
    "defaultText": "🌙 半部《甄嬛传》"
  },

  "factorChipStyle": {
    "_comment": "factor chip 配色（快/慢/中）",
    "fast": { "bg": "#e8f5e9", "fg": "#2e7d32", "label": "↑ 快" },
    "slow": { "bg": "#fff3e0", "fg": "#ef6c00", "label": "↓ 慢" },
    "neutral": { "bg": "#f5f5f5", "fg": "#616161", "label": "· 中" }
  },

  "riderChipEmoji": {
    "_comment": "骑手 chip emoji（按倍率决定快/慢）",
    "fast": "⚡",
    "slow": "🐢",
    "neutral": "🚴"
  },

  "_debugHooks": {
    "_comment": "调试时改这里快速试值（不改代码）",
    "forceAllMultiplier": 1.0,
    "forceDelivery": null,
    "forceCooking": null
  }
