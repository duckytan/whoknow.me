  "bossSpeedMult": {
    "_comment": "老板性格 → 出餐速度倍率",
    "_schema": "Record<personality, number>",
    "angry": 1.2,
    "lazy": 1.5,
    "gentle": 0.9,
    "weird": 1.5,
    "philosophical": 1.3,
    "_legacy": {
      "_comment": "旧版兼容性，新游戏不用",
      "zen": 0.9,
      "cool": 1.0,
      "warm": 0.95,
      "silly": 1.1,
      "mystery": 1.0,
      "chaotic": 1.3
    }
  },

  "bossLabels": {
    "_comment": "老板性格 → 中文标签",
    "_schema": "Record<personality, string>",
    "angry": "暴躁",
    "gentle": "温柔",
    "lazy": "拖延",
    "weird": "诡异",
    "philosophical": "哲学"
  },

  "bossEmoji": {
    "_comment": "老板性格 → chip emoji（>1 = 慢/烦, <1 = 快/开心）",
